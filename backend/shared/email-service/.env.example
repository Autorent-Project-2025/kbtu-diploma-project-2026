# Docker settings
EXTERNAL_PORT=9182

PORT=8080
SMTP_VERIFY_ON_STARTUP=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Autorent App <no-reply@autorent-app.com>"
RABBITMQ_URL=amqp://autorent:autorent@rabbitmq:5672
RABBITMQ_EXCHANGE=autorent.events
EMAIL_EVENT_DEDUP_TTL_MS=900000
OBSERVABILITY_LOG_PATH=/tmp/autorent/email-service/email-service.jsonl
