@startuml
!pragma layout smetana

left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam BackgroundColor white
skinparam ArrowColor #2F4F4F
skinparam NoteBackgroundColor #FFF8DC
skinparam NoteBorderColor #BDB76B
skinparam defaultTextAlignment center

skinparam package {
  BorderColor #2F4F4F
  FontStyle bold
}

skinparam component {
  BorderColor #2F4F4F
  FontColor #111111
  BackgroundColor #F8FAFC
}

skinparam database {
  BorderColor #2F4F4F
  BackgroundColor #ECFDF5
}

title AutoRent - Project Architecture (PlantUML)

actor "Customer" as customer
actor "Manager" as manager
actor "Superadmin" as superadmin

package "Frontend" {
  component "External Frontend\nVue 3 + Vite\nport: 5173" as FE_EXT
  component "Internal Frontend\nVue 3 + Vite\nport: 5174" as FE_INT
  component "Superadmin Frontend\nVue 3 + Vite\nport: 5175" as FE_SUPER
}

package "Edge" {
  component "API Gateway\nNode.js + Express\nhttp-proxy-middleware\nport: 9186" as GATEWAY
}

package "Core Services" {
  component "Identity Service\nASP.NET Core\nport: 1244" as IDENTITY
  component "Car Service\nASP.NET Core\nport: 1298" as CAR
  component "Booking Service\nASP.NET Core\nport: 1821" as BOOKING
  component "Ticket Service\nASP.NET Core\nport: 1248" as TICKET
  component "Email Service\nNode.js\nport: 9182" as EMAIL
  component "Image Service\nNode.js + Express\nport: 9181" as IMAGE
}

package "Data" {
  database "identity-db\nPostgreSQL" as DB_ID
  database "car-db\nPostgreSQL" as DB_CAR
  database "booking-db\nPostgreSQL" as DB_BOOK
  database "ticket-db\nPostgreSQL" as DB_TICKET
  collections "image_uploads\nDocker Volume" as IMG_VOL
}

package "Migration Layer" {
  component "identity-flyway" as FW_ID
  component "car-flyway" as FW_CAR
  component "booking-flyway" as FW_BOOK
  component "ticket-flyway" as FW_TICKET
}

cloud "External Providers" {
  component "SMTP Provider\n(e.g. Gmail SMTP)" as SMTP
  component "Google Cloud Storage\n(optional)" as GCS
}

customer --> FE_EXT
manager --> FE_INT
superadmin --> FE_SUPER

FE_EXT --> GATEWAY : REST (VITE_API_URL)
FE_INT --> GATEWAY : REST (VITE_API_URL)
FE_SUPER --> GATEWAY : REST (VITE_API_URL)

GATEWAY --> IDENTITY : /identity/*
GATEWAY --> CAR : /cars/*
GATEWAY --> BOOKING : /bookings/*
GATEWAY --> TICKET : /tickets/*
GATEWAY --> IMAGE : /internal/*

IDENTITY --> DB_ID
CAR --> DB_CAR
BOOKING --> DB_BOOK
TICKET --> DB_TICKET

FW_ID --> DB_ID : migrate
FW_CAR --> DB_CAR : migrate
FW_BOOK --> DB_BOOK : migrate
FW_TICKET --> DB_TICKET : migrate

TICKET --> IDENTITY : POST /internal/users/provision\nX-Internal-Api-Key
TICKET --> EMAIL : POST /emails/approved\nPOST /emails/rejected

EMAIL --> SMTP : send emails
IMAGE --> IMG_VOL : local storage\n(USE_WEB_STORAGE=false)
IMAGE --> GCS : object storage\n(USE_WEB_STORAGE=true)

IDENTITY ..> CAR : JWT validation key
IDENTITY ..> BOOKING : JWT validation key
IDENTITY ..> TICKET : JWT validation key

note bottom of GATEWAY
Route rewrite in gateway:
/identity -> identity-service
/cars -> car-service
/bookings -> booking-service
/tickets -> ticket-service
/internal -> image-service
end note

@enduml
